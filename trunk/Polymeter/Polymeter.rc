                MENUITEM "&Silver Style",               ID_VIEW_APPLOOK_OFF_2007_SILVER
                MENUITEM "&Aqua Style",                 ID_VIEW_APPLOOK_OFF_2007_AQUA
            END
        END
        MENUITEM SEPARATOR
        MENUITEM "&Properties",                 ID_VIEW_PROPERTIES
        MENUITEM "&Channels",                   ID_VIEW_CHANNELS
        POPUP "&Groups"
        BEGIN
            MENUITEM "&Presets",                    ID_VIEW_PRESETS
            MENUITEM "P&arts",                      ID_VIEW_PARTS
        END
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&Devices",                    ID_TOOLS_DEVICES
